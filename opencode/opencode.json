{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    //"opencode-gemini-auth@latest"
  ],
  "tools": {
    "webfetch": true,
    "websearch": true
  },
  "permission": {
    "read": "allow",
    "edit": "ask",
    "bash": "ask",
    "webfetch": "ask",
    "websearch": "ask"
  },
  "provider": {
    "loca-lmstudio": {
      "name": "local lmstudio",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "gemma4": {
          "name": "gemma4",
          "variants": {
            "architect": {
              "reasoningEffort": "high",
              "textVerbosity": "high",
              "reasoningSummary": "detailed"
            },
            "developer": {
              "reasoningEffort": "medium",
              "textVerbosity": "medium",
              "reasoningSummary": "none"
            },
            "assistant": {
              "reasoningEffort": "low",
              "textVerbosity": "high",
              "reasoningSummary": "none"
            }
          }
        }
      }
    }
  }
}